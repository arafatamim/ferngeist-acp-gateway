{
  "id": "codex-acp",
  "displayName": "Codex ACP",
  "protocol": "acp",
  "platformSupport": ["windows", "darwin", "linux"],
  "detection": {
    "mode": "path_lookup",
    "command": "codex-acp"
  },
  "launch": {
    "mode": "external",
    "command": "codex-acp",
    "args": [],
    "transport": "stdio",
    "readiness": {
      "mode": "immediate"
    },
    "restart": {
      "mode": "never"
    }
  },
  "healthCheck": {
    "mode": "none"
  },
  "capabilities": ["acp"],
  "security": {
    "curatedLaunch": true,
    "allowsRemoteStart": true,
    "userConfigurableFields": []
  },
  "registry": {
    "required": true,
    "validationStatus": "unavailable"
  },
  "hint": "Detected when `codex-acp` is available on PATH and validated against the ACP registry."
}
